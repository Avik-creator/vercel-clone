# Server Configuration
HOST=0.0.0.0
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/vercel_clone

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# GitHub App Configuration
# Create a GitHub App at https://github.com/settings/apps
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Build Worker
BUILD_WORKER_SECRET=your-build-worker-secret

# Domain Configuration
BASE_DOMAIN=localhost

# NATS (Message Queue)
NATS_URL=nats://localhost:4222

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000
