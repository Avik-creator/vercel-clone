# Server Configuration
HOST=0.0.0.0
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/vercel_clone

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# GitHub App Configuration
# Create a GitHub App at https://github.com/settings/apps
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Build Worker
BUILD_WORKER_SECRET=your-build-worker-secret

# Domain Configuration
BASE_DOMAIN=localhost
# Public API URL for OAuth callbacks (e.g. http://localhost:8080 or https://api.example.com)
API_PUBLIC_URL=http://localhost:8080

# NATS (Message Queue)
NATS_URL=nats://localhost:4222
# Path to CA cert for NATS TLS (optional; set in docker-compose for production)
# NATS_TLS_CA=/certs/ca.pem

# Admin API (defaults to BUILD_WORKER_SECRET when unset)
# ADMIN_SECRET=your-admin-secret

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000
